<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="800.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.AdminDashboard.ManageTimetablesController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Timetable &amp; Scheduling" textFill="#2c3e50">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 10;">
                    <children>
                        <ComboBox fx:id="cmbFilterDay" prefHeight="35.0" prefWidth="150.0" promptText="Select Day" />
                        <ComboBox fx:id="cmbFilterBatch" prefHeight="35.0" prefWidth="150.0" promptText="Select Batch" />
                        <TextField fx:id="txtSearchSchedule" prefHeight="35.0" prefWidth="250.0" promptText="Search Course/Hall..." style="-fx-background-radius: 5;" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <children>
                                <Button onAction="#btnOnActionAddNewSchedule" prefHeight="35.0" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;" text="+ ADD SESSION" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblTimetable" prefHeight="400.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDay" prefWidth="100.0" text="Day" />
                        <TableColumn fx:id="colTime" prefWidth="150.0" text="Time Slot" />
                        <TableColumn fx:id="colCourse" prefWidth="200.0" text="Course Name" />
                        <TableColumn fx:id="colLocation" prefWidth="120.0" text="Hall/Lab" />
                        <TableColumn fx:id="colBatch" prefWidth="100.0" text="Batch" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button onAction="#btnOnActionUpdateSchedule" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit" />
                        <Button onAction="#btnOnActionDeleteSchedule" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>